## Capacity Agent - Environment Variables
##
## Copy to .env and fill in real values before running docker compose

# PostgreSQL
PG_PASSWORD=capacity_dev_change_me

# ClickHouse
CH_PASSWORD=capacity_dev_change_me

# Grafana
GRAFANA_PASSWORD=admin_change_me

# LLM model (Qwen2.5-32B 推荐, 7B 用于低算力试运行)
LLM_MODEL=Qwen/Qwen2.5-32B-Instruct
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# vLLM 张量并行 (32B 用 2, 7B 用 1)
TENSOR_PARALLEL_SIZE=2
